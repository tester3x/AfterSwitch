rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // User's own cloud profiles (private per user)
    // afterswitch_profiles/{uid}/profiles/{profileId}
    // ============================================================
    match /afterswitch_profiles/{uid}/profiles/{profileId} {
      // Only the profile owner can read/write
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ============================================================
    // Shared community profiles (public browse, owner-only write)
    // shared_profiles/{sharedId}
    // ============================================================
    match /shared_profiles/{sharedId} {
      // Any authenticated user can browse/read shared profiles
      allow read: if request.auth != null;

      // Only the profile owner can create (must set ownerUid to their uid)
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      // Only the owner can delete their own shared profile
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      // Allow download count increment by anyone authenticated,
      // but ONLY the downloads field can change (no other fields)
      allow update: if request.auth != null
                    && (
                      // Owner can update anything
                      resource.data.ownerUid == request.auth.uid
                      // Non-owner can ONLY increment downloads
                      || (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads'])
                        && request.resource.data.downloads == resource.data.downloads + 1
                      )
                    );
    }

    // ============================================================
    // Deny everything else by default
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
